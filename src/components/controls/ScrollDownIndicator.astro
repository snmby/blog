---
import { Icon } from "astro-icon/components";

interface Props {
	targetId?: string;
	class?: string;
	ariaLabel?: string;
	hideOffset?: number;
}

const {
	targetId = "main-grid",
	class: className,
	ariaLabel = "Scroll down",
	hideOffset,
} = Astro.props as Props;
---

<button
  type="button"
  class:list={["scroll-down-indicator", className]}
  data-scroll-down-indicator
  data-hide-offset={hideOffset ?? ""}
  aria-label={ariaLabel}
  onclick={`document.getElementById(${JSON.stringify(targetId)})?.scrollIntoView({ behavior: 'smooth' })`}
>
  <Icon name="material-symbols:keyboard-arrow-down-rounded" class="scroll-down-icon" />
</button>

<script is:inline>
  (function () {
    if (window.__scrollDownIndicatorInit) {
      window.__scrollDownIndicatorUpdate?.();
      return;
    }

    window.__scrollDownIndicatorInit = true;

    function updateVisibility() {
      var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
      var indicators = document.querySelectorAll("[data-scroll-down-indicator]");

      indicators.forEach(function (indicator) {
        var hideOffsetAttr = indicator.getAttribute("data-hide-offset");
        var hideOffset = hideOffsetAttr ? Number(hideOffsetAttr) : null;

        if (hideOffset !== null && scrollTop > hideOffset) {
          indicator.classList.add("hide");
        } else {
          indicator.classList.remove("hide");
        }
      });
    }

    window.__scrollDownIndicatorUpdate = updateVisibility;

    window.addEventListener("scroll", updateVisibility, { passive: true });
    document.addEventListener("astro:page-load", updateVisibility);
    document.addEventListener("swup:contentReplaced", updateVisibility);
    updateVisibility();
  })();
</script>
