---
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin</title>
    <link rel="icon" href={`${baseUrl}favicon/favicon.ico`} />
    <link rel="cms-config-url" type="text/yaml" href={`${baseUrl}admin/config.yml`} />
    <style>
      html,
      body {
        margin: 0;
        min-height: 100%;
        background: #0b1020;
        color: #e5e7eb;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      body {
        padding: 24px;
      }

      #nc-root {
        min-height: calc(100vh - 48px);
      }

      .admin-status {
        display: grid;
        place-items: center;
        min-height: calc(100vh - 48px);
        text-align: center;
      }

      .admin-status[hidden] {
        display: none;
      }

      .admin-card {
        max-width: 32rem;
      }

      .admin-card h1 {
        margin: 0 0 12px;
        font-size: 1.5rem;
      }

      .admin-card p {
        margin: 0;
        color: #9ca3af;
        line-height: 1.6;
      }

      .admin-card code {
        color: #e5e7eb;
      }
    </style>
  </head>
  <body>
    <div id="admin-status" class="admin-status" data-base-url={baseUrl}>
      <div class="admin-card">
        <h1>Loading admin</h1>
        <p>If this page stays blank, check the browser console and the <code>config.yml</code> path.</p>
      </div>
    </div>
    <div id="nc-root"></div>
    <script>
      const statusEl = document.getElementById("admin-status");
      const baseUrl = statusEl?.getAttribute("data-base-url") || "/";

      window.CMS_MANUAL_INIT = true;

      window.addEventListener("load", async () => {
        try {
          const { default: CMS } = await import("decap-cms");
          CMS.init();

          const rootEl = document.getElementById("nc-root");
          const hideStatus = () => statusEl?.setAttribute("hidden", "");

          if (rootEl?.hasChildNodes()) {
            hideStatus();
            return;
          }

          const observer = new MutationObserver(() => {
            if (rootEl?.hasChildNodes()) {
              hideStatus();
              observer.disconnect();
            }
          });

          if (rootEl) {
            observer.observe(rootEl, { childList: true });
          }
        } catch (error) {
          console.error("Failed to initialize Decap CMS:", error);

          if (statusEl) {
            statusEl.innerHTML = `
              <div class="admin-card">
                <h1>Admin failed to load</h1>
                <p>Make sure <code>${baseUrl}admin/config.yml</code> is reachable, then check the browser console for details.</p>
              </div>
            `;
          }
        }
      });
    </script>
  </body>
</html>
